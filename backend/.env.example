# Aplicação
ENVIRONMENT=development
LOG_LEVEL=INFO
LEVELING_NUM_QUESTIONS=5

# Banco de dados - psycopg3 para SQLAlchemy
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/academic-ai-db

# Checkpointer LangGraph - psycopg3 direto (sem prefixo SQLAlchemy)
CHECKPOINTER_URL=postgresql://postgres:postgres@localhost:5432/academic-ai-db

# LLM
LLM_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# OpenAI (necessário apenas se LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=documents
QDRANT_VECTOR_SIZE=1536

# RAG
CHUNK_SIZE_TOKENS=1024
CHUNK_OVERLAP_TOKENS=154
MAX_UPLOAD_SIZE_MB=10
